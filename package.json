{
  "name": "syntrophic-reputation-protocol",
  "version": "2.0.0",
  "description": "Day-zero trust layer for ERC-8004 agents on Base with Oasis ROFL-validated attestations and portable on-chain metadata",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:demo": "bash scripts/setup.sh --demo",
    "setup:start": "bash scripts/setup.sh --demo --start",
    "setup:full": "bash scripts/setup.sh",
    "validate": "bash scripts/validate-env.sh",
    "validate:demo": "bash scripts/validate-env.sh --demo",
    "doctor": "npm run validate",
    "build": "npm run build:protocol && npm run build:frontend",
    "build:protocol": "cd protocol && forge build",
    "build:frontend": "cd frontend && npm run build",
    "dev": "npm run dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "cd frontend && npm run start",
    "launch:agent": "cd frontend && npm run launch:agent",
    "demo:paid-launch": "cd frontend && npm run demo:paid-launch",
    "demo:prepare": "cd frontend && npm run demo:prepare",
    "demo:batch": "cd frontend && npm run demo:batch",
    "demo:judge-prepare": "npm run demo:prepare",
    "demo:judge-batch": "npm run demo:batch",
    "test": "cd protocol && forge test --offline",
    "test:protocol": "npm test",
    "test:vault": "cd protocol && forge test --match-contract SRPVaultTest --offline",
    "test:adapter": "cd protocol && forge test --match-contract ERC8004RegistryAdapterTest --offline",
    "test:onboarder": "cd protocol && forge test --match-contract SyntrophicOnboarderTest --offline",
    "test:verbose": "cd protocol && forge test --offline -vvv",
    "test:gas": "cd protocol && forge test --offline --gas-report",
    "deploy": "npm run deploy:stack",
    "deploy:stack": "cd protocol && forge script script/DeployMainnetStackV2.s.sol:DeployMainnetStackV2 --rpc-url $BASE_RPC_URL --private-key $PRIVATE_KEY --broadcast --verify",
    "deploy:adapter": "cd protocol && forge script script/DeployERC8004RegistryAdapter.s.sol:DeployERC8004RegistryAdapter --rpc-url $BASE_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "deploy:vault": "cd protocol && forge script script/DeploySRPVault.s.sol:DeploySRPVault --rpc-url $BASE_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "deploy:onboarder": "cd protocol && forge script script/DeploySyntrophicOnboarder.s.sol:DeploySyntrophicOnboarder --rpc-url $BASE_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "deploy:sponsored-onboarder": "cd protocol && forge script script/DeploySyntrophicSponsoredOnboarder.s.sol:DeploySyntrophicSponsoredOnboarder --rpc-url $BASE_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "verify": "npm run verify:all",
    "verify:bond": "bash scripts/verify-base.sh bond",
    "verify:agent": "bash scripts/verify-base.sh agent",
    "verify:status": "bash scripts/verify-base.sh status",
    "verify:score": "bash scripts/verify-base.sh score",
    "verify:all": "bash scripts/verify-base.sh all",
    "lint": "cd frontend && npm run lint",
    "clean": "cd protocol && forge clean && cd ../frontend && rm -rf .next"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Syntrophic-MD/syntrophic-reputation-protocol.git"
  },
  "keywords": [
    "erc-8004",
    "ai-agents",
    "trust",
    "reputation",
    "bonding",
    "base",
    "rofl",
    "attestation",
    "ethereum"
  ],
  "license": "MIT",
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  }
}
